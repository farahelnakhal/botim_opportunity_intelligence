# BOTIM Product Discovery Copilot backend - example configuration
# Copy to .env (gitignored) or export in your shell. PLACEHOLDERS ONLY.

# ---- Canonical LLM configuration (all services; vendor-neutral) ----------
# The ONLY variables a deployment needs for a live model:
BOTIM_LLM_API_KEY=REPLACE_ME
BOTIM_LLM_MODEL=claude-sonnet-5
# Required for any OpenAI-compatible endpoint (Groq, OpenAI, Ollama, vLLM...);
# not needed for Anthropic (inferred from a claude-* model / sk-ant- key) or
# when GROQ_API_KEY is the key source (Groq endpoint implied):
#BOTIM_LLM_BASE_URL=https://api.groq.com/openai/v1
# Explicit override: anthropic | openai_compatible | mock.
# mock is the deterministic demo responder and is NEVER selected implicitly:
#BOTIM_LLM_PROVIDER=

# Optional vendor ALIASES (resolve into the canonical values above):
#ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
#GROQ_API_KEY=gsk_REPLACE_ME
#COPILOT_PROVIDER=mock              # alias of BOTIM_LLM_PROVIDER (tests/dev)
#COPILOT_MODEL=claude-sonnet-5      # alias of BOTIM_LLM_MODEL

# ---- Service settings -----------------------------------------------------
COPILOT_TIMEOUT_S=60
COPILOT_MAX_HISTORY=20
COPILOT_MAX_TOOL_ITERATIONS=3
COPILOT_MAX_RESPONSE_CHARS=20000
COPILOT_MAX_MESSAGE_CHARS=4000
COPILOT_HOST=127.0.0.1              # never 0.0.0.0 without COPILOT_API_TOKEN
COPILOT_PORT=8010
COPILOT_CORS_ORIGIN=http://localhost:8000
COPILOT_API_TOKEN=                  # required if COPILOT_HOST is non-local
COPILOT_DEBUG_TRACE=0               # 1 = include safe_tool_trace in responses (dev only)
