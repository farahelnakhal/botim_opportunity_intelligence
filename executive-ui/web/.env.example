# executive-ui/web — example configuration (Integration Phase 2)
# Copy to .env or .env.local (both gitignored) to override for local dev or a
# non-proxied production build. PLACEHOLDERS ONLY — never commit real values.
#
# Left unset, both default to relative paths (/executive-api, /copilot-api)
# that work with either the Vite dev-server proxy (see vite.config.ts) or a
# single-origin production deploy where executive-ui/api/server.py serves the
# built frontend and fronts both prefixes itself (see
# executive-ui/deploy/start.sh). Only set these if the two backends are
# deployed on genuinely different origins from the frontend.
VITE_EXECUTIVE_API_BASE_URL=
VITE_COPILOT_API_BASE_URL=

# Phase 5 — build-time hint ONLY (the backend's BOTIM_APP_MODE is the source
# of truth for the effective mode). Set to "demo" for demo-showcase builds so
# the bundled demo seed may act as the offline fallback when the API is
# unreachable. Leave unset (normal) for real builds: an unreachable API then
# shows an honest unavailable/empty state, never demo data.
VITE_APP_MODE=
