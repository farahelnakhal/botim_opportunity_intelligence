# Merchant Voice & Validation backend - example configuration
# PROTOTYPE-GRADE AUTH. SYNTHETIC-DATA-ONLY. NOT FOR PRODUCTION.
# Copy to .env (gitignored) or export in your shell. PLACEHOLDERS ONLY -
# never commit real tokens or keys.

MV_HOST=127.0.0.1
MV_PORT=8020
MV_CORS_ORIGIN=http://localhost:8000

MV_DB_PATH=merchant-voice/data/mv.db
MV_IDENTITY_DB_PATH=merchant-voice/data/identity.db
MV_TRANSCRIPT_DIR=merchant-voice/data/transcripts

MV_MAX_BODY_BYTES=5242880
MV_MAX_CONCURRENCY=4

MV_PROVIDER=mock                    # mock | anthropic
MV_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
MV_PROVIDER_TIMEOUT_S=60

# label:token:role,label:token:role,...  (roles: viewer|researcher|reviewer|admin)
# REPLACE all token values before any non-throwaway use. Never commit real tokens.
MV_TOKENS=admin:REPLACE_ME_ADMIN_TOKEN:admin,researcher:REPLACE_ME_RESEARCHER_TOKEN:researcher,reviewer:REPLACE_ME_REVIEWER_TOKEN:reviewer,viewer:REPLACE_ME_VIEWER_TOKEN:viewer

MV_ALLOW_SELF_APPROVAL=0             # 1 enables self-approval (always audited with self_approval=true)
MV_SYNTHETIC_ONLY=1                  # do not disable outside an approved, reviewed deployment

MV_CSV_PREVIEW_TTL_S=900             # CSV preview-token lifetime in seconds (default 15 minutes)
